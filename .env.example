# Copy to .env and adjust. Loaded by docker-compose; for `streamlit run` export
# these in your shell (the app reads them via os.getenv).

# --- Login (required in production; defaults to admin/admin otherwise) ---
APP_USERNAME=admin
APP_PASSWORD=change-me

# --- Ollama ---
# Local dev: http://localhost:11434 | Docker compose: http://ollama:11434
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=mistral

# --- Chat with Docs (EmbedChain) ---
EMBEDCHAIN_DB_DIR=data/embedchain
EMBEDCHAIN_EMBED_MODEL=nomic-embed-text
